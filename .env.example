# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage
LOCAL_DB_PATH=data/transactiq.db
MYSQL_URI=mysql+pymysql://user:password@localhost:3306/transactiq
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Security
TRANSACTIQ_API_KEY=
TRANSACTIQ_ADMIN_API_KEY=

# Model lifecycle
MODEL_DIR=data/models
RETRAIN_INTERVAL_MINUTES=0

# Dashboard (only needed when running outside Docker Compose)
API_BASE_URL=http://localhost:5000

# MySQL (only needed when running the mysql profile)
MYSQL_ROOT_PASSWORD=transactiq_root
MYSQL_USER=transactiq
MYSQL_PASSWORD=transactiq
